        <mxCell id="bBq_fYIeZNeF0TwLMKgw-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Youtube&lt;/h1&gt;&lt;p&gt;It is video sharing platfom that allow where to upload ,view ,video and interact with video content&amp;nbsp; .&lt;/p&gt;" vertex="1">
