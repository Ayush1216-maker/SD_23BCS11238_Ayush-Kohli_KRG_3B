        <mxCell id="Lj1HEmVJsNPDBe-fCg3b-21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Problem&amp;nbsp;&lt;div&gt;&lt;strong data-start=&quot;1097&quot; data-end=&quot;1134&quot;&gt;API Gateway payload limit (10 MB)&lt;/strong&gt;&lt;br data-start=&quot;1134&quot; data-end=&quot;1137&quot;&gt;&lt;br/&gt;If uploading through &lt;strong data-start=&quot;1161&quot; data-end=&quot;1202&quot;&gt;Amazon API Gateway&lt;/strong&gt;, the request payload limit is &lt;strong data-start=&quot;1233&quot; data-end=&quot;1242&quot;&gt;10 MB&lt;/strong&gt;.&lt;/div&gt;" vertex="1">
