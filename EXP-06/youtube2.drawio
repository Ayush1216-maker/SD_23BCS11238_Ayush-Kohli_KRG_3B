        <mxCell id="Lj1HEmVJsNPDBe-fCg3b-22" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Solution&lt;div&gt;When uploading through API Gateway, the request payload size limit is 10 MB, so large video uploads must bypass API Gateway and upload directly to storage using a pre-signed URL&lt;/div&gt;" vertex="1">
